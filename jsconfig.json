{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "paths": {
      "is-react-comp": ["./index.js"],
      "is-react-comp/*": ["./src/*"]
    }
  },
  "include": [
    "index.js",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
